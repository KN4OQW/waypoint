[Unit]
Description=Waypoint DGIdGateway (MQTT)
Conflicts=waypoint-ysfgateway.service
After=mosquitto.service waypoint-mmdvm.service
Wants=mosquitto.service

[Service]
# Runs the waypoint-stack package binary (/usr/bin) against the INI waypointd
# renders on Apply. Managed by waypointd: enabled/started when its mode is
# configured, health-gated on stack updates (RFC-0014). Not enabled at image
# build — a fresh, unclaimed node runs no gateways until it is configured.
ExecStart=/usr/bin/DGIdGateway /home/pi-star/waypoint/etc/DGIdGateway.ini
Restart=on-failure
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
